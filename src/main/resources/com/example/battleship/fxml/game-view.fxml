<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #090d16;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.battleship.controller.GameController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #0e1726; -fx-border-color: #00ffff; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 20px; -fx-text-fill: #00ffff; -fx-font-weight: bold;" text="CENTRO DE COMANDO NAVAL" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="turnLabel" style="-fx-font-size: 16px; -fx-text-fill: #ffffff; -fx-background-color: #1b2a47; -fx-padding: 6 12; -fx-background-radius: 4;" text="Cargando..." />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <HBox alignment="CENTER" spacing="50.0" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #00ffff; -fx-font-weight: bold;" text="DISPOSICIÓN DE TU FLOTA" />
                        <GridPane fx:id="playerGrid" style="-fx-background-color: #0c1322; -fx-padding: 5; -fx-border-color: rgba(0,255,255,0.4); -fx-border-radius: 4;" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #ff3333; -fx-font-weight: bold;" text="RADAR DE ATAQUE ENEMIGO" />
                        <GridPane fx:id="enemyGrid" style="-fx-background-color: #0c1322; -fx-padding: 5; -fx-border-color: rgba(255,51,51,0.4); -fx-border-radius: 4;" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0" style="-fx-background-color: #0e1726; -fx-border-color: #00ffff; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="actionStatusLabel" style="-fx-font-size: 13px; -fx-text-fill: #8fa0b5;" text="Consola de eventos de combate..." />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="viewEnemyShipsButton" onAction="#onViewEnemyShipsButtonClick" styleClass="btn-neon" text="Ver Barcos Enemigos" />
                <Button onAction="#onSurrenderButtonClick" styleClass="btn-dark" text="Retirarse" />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
