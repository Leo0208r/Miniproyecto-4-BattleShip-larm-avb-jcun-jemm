<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.battleship.controller.PlacementController">
   <children>
      <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true">
         <image>
            <Image url="@images/HD-wallpaper-naval-battle-sea-ships-warfare.jpg" />
         </image>
      </ImageView>

      <VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="1280.0" spacing="14.0">
         <padding>
            <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
         </padding>
         <children>
            <Label text="⚓ COLOCACIÓN DE FLOTA" textFill="#38bdf8">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>

            <HBox alignment="CENTER" spacing="18.0" style="-fx-background-color: rgba(15, 23, 42, 0.86); -fx-background-radius: 12; -fx-border-color: #38bdf8; -fx-border-radius: 12;">
               <padding>
                  <Insets bottom="10.0" left="18.0" right="18.0" top="10.0" />
               </padding>
               <children>
                  <Label fx:id="lblNickname" text="Comandante: Player1" textFill="#e2e8f0" />
                  <Label fx:id="lblCurrentShip" text="Siguiente barco: Portaaviones (4 celdas)" textFill="#f8fafc" />
                  <Label fx:id="lblOrientation" text="Orientación: HORIZONTAL" textFill="#fde68a" />
                  <Label fx:id="lblShipsPlaced" text="Barcos colocados: 0/10" textFill="#86efac" />
               </children>
            </HBox>

            <Label fx:id="lblPlacementStatus" text="Haz clic en una celda para colocar el barco actual." textFill="#e2e8f0">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>

            <HBox alignment="CENTER" spacing="12.0">
               <children>
                  <Button fx:id="btnRotate"
                          mnemonicParsing="false"
                          onAction="#handleRotate"
                          prefHeight="42.0"
                          prefWidth="130.0"
                          style="-fx-background-color: #0ea5e9;
                       -fx-text-fill: white;
                       -fx-background-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-cursor: hand;
                       -fx-border-color: #38bdf8;
                       -fx-border-radius: 8;"
                          text="↻ Rotar"/>

                  <Button fx:id="btnRandomFill"
                          mnemonicParsing="false"
                          onAction="#handleRandomFill"
                          prefHeight="42.0"
                          prefWidth="150.0"
                          style="-fx-background-color: #7c3aed;
                       -fx-text-fill: white;
                       -fx-background-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-cursor: hand;
                       -fx-border-color: #a78bfa;
                       -fx-border-radius: 8;"
                          text="🎲 Auto-llenar"/>

                  <Button fx:id="btnRestartPlacement"
                          mnemonicParsing="false"
                          onAction="#handleRestartPlacement"
                          prefHeight="42.0"
                          prefWidth="140.0"
                          style="-fx-background-color: #f59e0b;
                       -fx-text-fill: white;
                       -fx-background-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-cursor: hand;
                       -fx-border-color: #fbbf24;
                       -fx-border-radius: 8;"
                          text="♻ Reiniciar"/>

                  <Button fx:id="btnStartBattle"
                          mnemonicParsing="false"
                          onAction="#handleStartBattle"
                          prefHeight="42.0"
                          prefWidth="180.0"
                          style="-fx-background-color: #16a34a;
                       -fx-text-fill: white;
                       -fx-background-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-cursor: hand;
                       -fx-border-color: #4ade80;
                       -fx-border-radius: 8;"
                          text="🚀 Iniciar Batalla"/>

                  <Button fx:id="btnBackToMenu"
                          mnemonicParsing="false"
                          onAction="#handleBackToMenu"
                          prefHeight="42.0"
                          prefWidth="120.0"
                          style="-fx-background-color: #334155;
                       -fx-text-fill: white;
                       -fx-background-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;
                       -fx-cursor: hand;
                       -fx-border-color: #64748b;
                       -fx-border-radius: 8;"
                          text="↩ Menú"/>
               </children>
            </HBox>

            <GridPane fx:id="gridPlacementBoard" gridLinesVisible="true" style="-fx-background-color: rgba(15, 23, 42, 0.95); -fx-border-color: #38bdf8; -fx-border-width: 2;">
               <padding>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
               </padding>
               <effect>
                  <DropShadow radius="10.0">
                     <color>
                        <Color red="0.2" green="0.7" blue="0.9" opacity="0.3" />
                     </color>
                  </DropShadow>
               </effect>
            </GridPane>
         </children>
      </VBox>
   </children>
</StackPane>
